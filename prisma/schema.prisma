// MTBF/MTTR 설비 관리 시스템 Prisma 스키마

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 공장 (F1, F2)
model Factory {
  id        Int       @id @default(autoincrement())
  name      String    @unique // "F1", "F2"
  processes Process[]
  createdAt DateTime  @default(now())
}

// 공정 (라인)
model Process {
  id        Int       @id @default(autoincrement())
  name      String    // "54인치", "MSC", "포생산", "1호기", "2호기" ...
  factory   Factory   @relation(fields: [factoryId], references: [id])
  factoryId Int
  records   MonthlyRecord[]
  createdAt DateTime  @default(now())

  @@unique([factoryId, name])
}

// 월별 데이터
model MonthlyRecord {
  id            Int     @id @default(autoincrement())
  year          Int     // 2024, 2025
  month         Int     // 1 ~ 12

  process       Process @relation(fields: [processId], references: [id])
  processId     Int

  // 가동시간 (분)
  operatingTime Float?
  // 정지횟수
  stopCount     Int?
  // 정지시간 (분)
  stopTime      Float?
  // MTBF (고장간격) - 자동 계산 or 수동 입력
  mtbf          Float?
  // MTTR (수리복구) - 자동 계산 or 수동 입력
  mttr          Float?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([processId, year, month])
}


model Record {
  id        Int      @id @default(autoincrement())
  year      Int
  factory   String
  process   String
  month     Int

  runTime   Float
  downCount Int
  downTime  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, factory, process, month], name: "unique_record")
}

// 수리유형 기준표 (DATA_TYPE.csv lookup table)
model RepairTypeMaster {
  id             Int    @id @default(autoincrement())
  repairType     String @unique // 수리유형
  managementType String          // 관리구분 (Preventive/Reactive/Non-Repair)
  displayOrder   Int             // 표시순서
}

// 시설 사고/수리 원장 - long format (DATA_BASE.csv)
model RepairTypeRecord {
  id              Int      @id @default(autoincrement())
  no              Int      // NO
  year            Int      // 년도
  month           Int      // 월
  day             Int      // 일
  equipment       String   // 대표설비
  subEquipment    String?  // 구성설비
  repairItem      String?  // 수리항목
  incidentType    String?  // 사고분류
  description     String?  // 사고 처리 내용
  cause           String?  // 원인
  technician      String?  // 조치자
  technicianCount Int?     // 조치인원
  repairTime      Float?   // 수리시간
  repairType      String?  // 수리유형
  count           Int?     // 건수
  durationMin     Float?   // 시간(분)
  managementType  String?  // 관리구분 (Preventive/Reactive)
  quarter         String?  // 분기
  createdAt       DateTime @default(now())
}